{
	"name": "pogo-masterfile-monorepo",
	"module": "src/generate.ts",
	"type": "module",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"generate": "bun run src/generate.ts",
		"generate:go": "bun run generate -- --go-only",
		"generate:rust": "bun run generate -- --rust-only",
		"generate:ts": "bun run generate -- --ts-only",
		"generate:ts-loose": "bun run generate -- --ts-loose",
		"postgenerate": "bun run deprecated",
		"deprecated": "bun run src/update-deprecated.ts",
		"postdeprecated": "bun run format",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check",
		"format": "biome check --write --unsafe & (cd packages/rust && cargo fmt) & (cd packages/rust-api && cargo fmt) & (cd packages/go && gofmt -w .) & (cd packages/go-api && gofmt -w .); wait;"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/bun": "latest",
		"@types/node": "^25.6.0",
		"expect-type": "^1.1.0"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"dependencies": {}
}
