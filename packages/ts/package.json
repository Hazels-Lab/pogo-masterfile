{
	"name": "pogo-masterfile-types",
	"version": "0.1.4",
	"description": "Generated TypeScript type definitions for the Pokémon GO masterfile, plus a typed `parseMasterfile` helper that dispatches each entry to its concrete payload type.",
	"license": "MIT",
	"author": "Hazel's Lab (https://github.com/Hazels-Lab)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Hazels-Lab/pogo-masterfile.git",
		"directory": "packages/ts"
	},
	"homepage": "https://github.com/Hazels-Lab/pogo-masterfile#readme",
	"bugs": {
		"url": "https://github.com/Hazels-Lab/pogo-masterfile/issues"
	},
	"keywords": [
		"pokemon-go",
		"pokemon",
		"masterfile",
		"types",
		"typescript"
	],
	"type": "module",
	"sideEffects": false,
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts"
		},
		"./entries": {
			"types": "./dist/entries.d.ts"
		},
		"./types": {
			"types": "./dist/types.d.ts"
		},
		"./lookup-table": {
			"types": "./dist/lookup-table.d.ts"
		},
		"./deprecated": {
			"types": "./dist/deprecated.d.ts"
		},
		"./*": {
			"types": "./dist/*/index.d.ts"
		},
		"./*/entries": {
			"types": "./dist/*/entries.d.ts"
		},
		"./*/types": {
			"types": "./dist/*/types.d.ts"
		},
		"./*/lookup-table": {
			"types": "./dist/*/lookup-table.d.ts"
		},
		"./*/entries/*": {
			"types": "./dist/*/entries/*.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"check": "tsc --noEmit -p tsconfig.build.json"
	},
	"peerDependencies": {
		"typescript": ">=5.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	}
}
