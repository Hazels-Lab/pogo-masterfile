{
	"name": "pogo-masterfile-types",
	"private": true,
	"type": "module",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts"
		},
		"./entries": {
			"types": "./src/entries.ts"
		},
		"./types": {
			"types": "./src/types.ts"
		},
		"./*": {
			"types": "./src/*/index.ts"
		},
		"./*/entries": {
			"types": "./src/*/entries.ts"
		},
		"./*/types": {
			"types": "./src/*/types.ts"
		},
		"./*/entries/*": {
			"types": "./src/*/entries/*.ts"
		}
	}
}
