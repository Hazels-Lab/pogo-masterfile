{
	"name": "pogo-masterfile",
	"version": "0.1.21",
	"description": "Runtime API for the Pokémon GO masterfile. Loads, indexes, and queries entries with literal-typed lookups and per-group accessors. Built on `pogo-masterfile-types`.",
	"license": "MIT",
	"author": "Hazel's Lab (https://github.com/Hazels-Lab)",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Hazels-Lab/pogo-masterfile.git",
		"directory": "packages/ts-api"
	},
	"homepage": "https://github.com/Hazels-Lab/pogo-masterfile#readme",
	"bugs": {
		"url": "https://github.com/Hazels-Lab/pogo-masterfile/issues"
	},
	"keywords": [
		"pokemon-go",
		"pokemon",
		"masterfile",
		"api",
		"typescript"
	],
	"sideEffects": false,
	"main": "./dist/cjs/index.js",
	"module": "./dist/esm/index.js",
	"types": "./dist/esm/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/esm/index.d.ts",
			"import": "./dist/esm/index.js",
			"require": "./dist/cjs/index.js"
		},
		"./fetch": {
			"types": "./dist/esm/fetch.d.ts",
			"import": "./dist/esm/fetch.js",
			"require": "./dist/cjs/fetch.js"
		},
		"./errors": {
			"types": "./dist/esm/errors.d.ts",
			"import": "./dist/esm/errors.js",
			"require": "./dist/cjs/errors.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json && printf '{\"type\":\"module\"}\\n' > dist/esm/package.json && printf '{\"type\":\"commonjs\"}\\n' > dist/cjs/package.json",
		"check": "tsc --noEmit -p tsconfig.json",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"pogo-masterfile-types": "workspace:^"
	},
	"peerDependencies": {
		"typescript": ">=5.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	}
}
