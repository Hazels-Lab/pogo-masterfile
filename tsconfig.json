{
	"compilerOptions": {
		// Environment setup & latest features
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,

		// Bundler mode
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		// Best practices
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,

		// Some stricter flags (disabled by default)
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false,

		"types": ["bun"]
	},
	// Excludes are package boundaries: packages/ts-api/ and the ts-api templates
	// have their own tsconfigs and depend on workspace deps (pogo-masterfile-types)
	// that root-level tsc doesn't see.
	"exclude": ["node_modules", "packages/ts-api/**", "src/typescript-api/templates/**", "src/typescript-api/templates-stubs/**", "src/typescript-api/tests/**"]
}
